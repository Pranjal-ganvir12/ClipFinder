# ─── Environment ──────────────────────────────────────────────────────────────
CLIPFINDER_ENV=development  # development | production

# ─── Frontend URL (for CORS) ─────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ─── Cloudflare R2 (free tier: 10GB storage, 10M reads/month) ────────────────
# Get these from: Cloudflare Dashboard > R2 > Manage R2 API Tokens
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=clipfinder-videos
R2_PUBLIC_URL=  # e.g., https://pub-xxxxx.r2.dev

# ─── Turso Database (optional, free tier: 8GB) ───────────────────────────────
# Get these from: turso.tech dashboard
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# ─── Upload Limits ───────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=100
